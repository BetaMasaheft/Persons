            <listPerson>
                <person sex="1">
                    <persName><forename>Luigi</forename> <surname>Bonomi</surname></persName>
                    <persName><roleName type="title">padre</roleName></persName>
                    <persName><roleName type="title">reverendus pater</roleName></persName>
                    <occupation type="ecclesiastic">chaplain of the Italian troops in Italian East Africa and then of the hospital in Asmara</occupation>
                    <faith type="Catholicism"/>
                    <nationality type="Italy"/>
                    <residence ref="LOC1579Asmara">Asmara</residence>
                    <birth when="1841">1841 in Verona (Italy)</birth>
                    <death when="1927-02-02">2 February 1927 in Asmara (Eritrea)</death>
                    <floruit notBefore="1874" notAfter="1927">A companion of <persName ref="PRS3168Comboni"/>, who was active in 
                        <placeName ref="LOC5068Palest"/> and in the <placeName ref="wd:Q1049">Sudan</placeName>. He was put in prison 
                        by the Mahdists, managed to escape and was sent to <placeName ref="LOC2991Eritre"/> in <date when="1887"/>. 
                        He invited the Comboni sisters to come in Eritrea in <date when="1914"/>.</floruit>
                </person>
